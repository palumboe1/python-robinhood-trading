# Copy to .env and fill in. Never commit the real .env (it is git-ignored).

# Robinhood credentials
ROBINHOOD_USERNAME=your_email@example.com
ROBINHOOD_PASSWORD=your_password

# Base32 TOTP secret (NOT a rotating 6-digit code). Required to run the cron
# job unattended — a headless host cannot answer an SMS/app 2FA prompt.
ROBINHOOD_MFA_SECRET=

# Scheduled moving-average dip-buyer settings (cron_trade.py)
SYMBOL=NFLX        # ticker to watch
MA_WINDOW=20       # number of samples in the moving average
DROP_PCT=5         # percent the average must fall vs the previous run to buy
BUY_DOLLARS=5      # dollars of fractional shares to buy on a trigger
# STATE_FILE=state.json   # where price history + average are persisted (optional)
